# -----------------------------------------------
# EdgeBet Environment Variables
# -----------------------------------------------
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to GitHub
# -----------------------------------------------

# Supabase (get from supabase.com > your project > settings > API)
REACT_APP_SUPABASE_URL=your_supabase_project_url
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key

# API-Football (get from api-football.com — free tier = 100 calls/day)
REACT_APP_API_FOOTBALL_KEY=your_api_football_key

# The Odds API (get from the-odds-api.com — free tier = 500 calls/month)
REACT_APP_ODDS_API_KEY=your_odds_api_key
